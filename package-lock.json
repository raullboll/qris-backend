{
  "name": "qris-backend",
  "lockfileVersion": 3,
  "requires": true,
  "$schema": "https://railway.com/railway.schema.json",
  "packages": {},
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "ipv6EgressEnabled": false,
    "numReplicas": 1,
    "restartPolicyMaxRetries": 10,
    "restartPolicyType": "ON_FAILURE",
    "runtime": "V2",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 1
      }
    }
  }
}
